{
  "name": "scrumlo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source, no-login, ephemeral sprint room — estimation + retro in one link.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "vite build",
    "dev:web": "vite build --watch",
    "dev:worker": "wrangler dev",
    "dev": "concurrently -k -n web,worker -c blue,magenta \"npm:dev:web\" \"npm:dev:worker\"",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:flows": "node test/flows.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "partysocket": "^1.1.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wouter": "^3.7.0",
    "zustand": "^5.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "@tailwindcss/oxide"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.1.0",
    "wrangler": "^4.98.0"
  }
}
